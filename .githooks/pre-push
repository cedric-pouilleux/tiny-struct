#!/bin/bash

echo "🔍 Exécution des vérifications avant le push..."

PROJECT_DIR="/home/mino/dev/tiny-struct/app"

if [ ! -f "$PROJECT_DIR/package.json" ]; then
    echo "❌ Aucun fichier package.json trouvé dans $PROJECT_DIR. Vérifiez la structure de votre projet !"
    exit 1
fi

cd "$PROJECT_DIR" || exit

if ! command -v pnpm &> /dev/null; then
    echo "❌ pnpm n'est pas installé. Veuillez l'installer d'abord !"
    exit 1
fi

if [ ! -d "node_modules" ]; then
    echo "📦 Installation des dépendances..."
    pnpm install
fi

echo "🧪 Vérification des types TypeScript..."
pnpm vue-tsc --noEmit

if [ $? -ne 0 ]; then
    echo "❌ La vérification des types a échoué ! Push annulé."
    exit 1
fi

echo "🧪 Exécution des tests unitaires..."
pnpm test:unit --run

if [ $? -ne 0 ]; then
    echo "❌ Les tests unitaires ont échoué ! Push annulé."
    exit 1
fi

echo "✅ Toutes les vérifications sont réussies ! Poursuite du push..."
